# API port (3000 is often taken by other tools; 3001 avoids most clashes)
PORT=3001

# MSSQL connection
DB_HOST=192.168.100.181
DB_PORT=1433
DB_USERNAME=SA
DB_PASSWORD=<PASTE_YOUR_PASSWORD_HERE>
DB_NAME=master

# SQL Server TLS options
DB_ENCRYPT=true
DB_TRUST_SERVER_CERT=true

# Microsoft Entra API authorization
ENTRA_TENANT_ID=
ENTRA_API_AUDIENCE=
ENTRA_ADMIN_ROLE=Admin

# HubSpot sandbox contact sync
# Use a private app token from the HubSpot sandbox account, not production.
HUBSPOT_ACCESS_TOKEN=
HUBSPOT_SYNC_SOURCE=backend_sandbox_test
HUBSPOT_SYNC_MAX_CONTACTS=1000
HUBSPOT_SYNC_BATCH_SIZE=100
# Optional override for tests/mocks. Leave blank for HubSpot.
HUBSPOT_BASE_URL=

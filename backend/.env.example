PORT=3001

DB_HOST=192.168.100.181
DB_PORT=1433
DB_USERNAME=SA
DB_PASSWORD=<PASTE_YOUR_PASSWORD_HERE>
DB_NAME=master

DB_ENCRYPT=true
DB_TRUST_SERVER_CERT=true

ENTRA_TENANT_ID=
ENTRA_CLIENT_ID=
ENTRA_CLIENT_SECRET=
ENTRA_ADMIN_ROLE=Admin
ENTRA_API_AUDIENCE=

# HubSpot sandbox contact sync
# Use a private app token from the HubSpot sandbox account, not production.
HUBSPOT_ACCESS_TOKEN=
HUBSPOT_SYNC_SOURCE=backend_sandbox_test
HUBSPOT_SYNC_MAX_CONTACTS=1000
HUBSPOT_SYNC_BATCH_SIZE=100
# Optional override for tests/mocks. Leave blank for HubSpot.
HUBSPOT_BASE_URL=

# Optional Microsoft Graph app-only writes for manual EMS -> Entra sync.
# Uses application permissions from the Entra app registration with /.default.
ENTRA_GRAPH_CLIENT_ID=
ENTRA_GRAPH_CLIENT_SECRET=

# Optional fixed temp password for created Entra users. If omitted, one strong password is generated per user.
ENTRA_SYNC_TEMP_PASSWORD=

ONEDRIVE_USER=
DOCUMENT_TOGGLE_USER=

# Where engagement folders are provisioned and browsed: 'sharepoint' (default) or 'onedrive'.
# When 'onedrive', engagement documents live in the OneDrive at ONEDRIVE_USER (which must be set,
# licensed for OneDrive, and initialized). Requires Files.ReadWrite.All (Application) on the Entra app.
ENGAGEMENT_DOCUMENT_SOURCE=sharepoint

# Contract extraction (Claude). When ANTHROPIC_API_KEY is set, uploaded third-party
# contracts are extracted semantically (any format) with per-field confidence + source,
# and scanned/image-only PDFs are read directly by the model. If left blank, extraction
# falls back to the deterministic label/regex parser (IAE's own fillable form still works).
ANTHROPIC_API_KEY=
# Optional overrides:
ANTHROPIC_MODEL=claude-opus-4-8
# Cap on document characters sent per extraction (guards cost on long technical-rider packets).
CONTRACT_LLM_MAX_INPUT_CHARS=160000

# SharePoint folder management – custom site for engagement folder creation
# SHAREPOINT_SITE_HOSTNAME=innovationae.sharepoint.com
# SHAREPOINT_SITE_PATH=/sites/IAECloudServer
# SHAREPOINT_ENGAGEMENTS_ROOT_FOLDER=Engagements

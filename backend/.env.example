# API port (3000 is often taken by other tools; 3001 avoids most clashes)
PORT=3001

# MSSQL connection
DB_HOST=192.168.100.181
DB_PORT=1433
DB_USERNAME=SA
DB_PASSWORD=<PASTE_YOUR_PASSWORD_HERE>
DB_NAME=master

# SQL Server TLS options
DB_ENCRYPT=true
DB_TRUST_SERVER_CERT=true

# Microsoft Entra API authorization
ENTRA_TENANT_ID=
# Audience accepted for verified user tokens — must match the token's `aud` claim.
# Use the api:// form (e.g. api://<api-app-client-id>); the verifier also derives the bare-GUID variant.
# Required for any token-verified endpoint (e.g. the Document Library OneDrive source gate).
ENTRA_API_AUDIENCE=
ENTRA_ADMIN_ROLE=Admin

# Optional Microsoft Graph app-only writes for manual EMS -> Entra sync.
# Uses application permissions from the Entra app registration with /.default.
ENTRA_GRAPH_CLIENT_ID=
ENTRA_GRAPH_CLIENT_SECRET=

# Optional fixed temp password for created Entra users. If omitted, one strong password is generated per user.
ENTRA_SYNC_TEMP_PASSWORD=

# Document Library – Microsoft Graph app-only (client credentials)
# ENTRA_CLIENT_ID=
# ENTRA_CLIENT_SECRET=

# Document Library – admin-only OneDrive source toggle
# ONEDRIVE_USER: UPN or object id of the user whose OneDrive the 'OneDrive' source reads from
# ONEDRIVE_USER=
# DOCUMENT_TOGGLE_USER: oid (preferred) or email allowed to use the OneDrive source
# DOCUMENT_TOGGLE_USER=

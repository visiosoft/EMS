# Copy to `.env` in the repository root (same folder as `vite.config.ts`).
# Vite reads root `.env*` first; if a `frontend/` directory exists, `frontend/.env*` is merged in,
# but root keys override duplicates.
#
# Azure / static hosting: VITE_* values are baked in when you run `npm run build`. They are not read
# from `.env` on the server at request time. Set the same variables in your CI/CD build environment
# (e.g. GitHub Actions repository variables) or rebuild after changing them.
#
# Entra redirect: leave VITE_ENTRA_REDIRECT_URI empty to use the current site origin + VITE_ENTRA_REDIRECT_PATH.
# Register that full URL (e.g. https://your-app.azurewebsites.net/login) in the Entra app registration.

VITE_API_URL=

VITE_ENTRA_CLIENT_ID=ce7e14f1-19c8-487d-85ca-59c5634fd981
VITE_ENTRA_TENANT_ID=68d9e837-5bda-45c5-9c45-c26b24492209
VITE_ENTRA_API_SCOPE=api://ce7e14f1-19c8-487d-85ca-59c5634fd981/Roles
VITE_ENTRA_GRAPH_SCOPE=https://graph.microsoft.com/User.Read.All
VITE_ENTRA_REDIRECT_URI=
VITE_ENTRA_REDIRECT_PATH=/login

# Optional — only for a future split deploy to separate domains. Normal releases: omit this line.
# Values: all (default) | ems | internal
# VITE_APP_SUITE=all

VITE_GOOGLE_PLACES_API_KEY=
